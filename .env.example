FLASK_APP=app.py
FLASK_ENV=development
DB_BACKEND=sqlite
SQLITE_DATABASE_PATH=database/disaster_management.db
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
SEED_SAMPLE_DATA=True
APP_HOST=127.0.0.1
APP_PORT=5000

# To switch to Microsoft SQL Server later, replace the local SQLite settings with:
# DB_BACKEND=sqlserver
# SQLSERVER_HOST=localhost
# SQLSERVER_PORT=1433
# SQLSERVER_DATABASE=disaster_management_new_db
# SQLSERVER_USER=sa
# SQLSERVER_PASSWORD=your_password
# SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
# SQLSERVER_ENCRYPT=no
# SQLSERVER_TRUST_SERVER_CERTIFICATE=yes

# To use MySQL instead:
# DB_BACKEND=mysql
# MYSQL_HOST=localhost
# MYSQL_PORT=3300
# MYSQL_DATABASE=disaster_management_new_db
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
